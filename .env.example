# =================================================================
# Plantilla de variables de entorno (.env.example)
# Copia este archivo como '.env' y completa los valores reales.
# No subas el archivo .env a Git (está en .gitignore).
# =================================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development
# Ruta opcional para la base local JSON del panel docente
# DATA_FILE=data/comprendo.json

# --- WhatsApp / Twilio (implementación actual del bot) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
# Número del estudiante de prueba (formato whatsapp:+..., según Twilio)
STUDENT_NUMBER=
# Opcional: notificación al docente por WhatsApp
TEACHER_NUMBER=
# Opcional: token para verificar webhooks de Twilio/Meta si lo configuras
WEBHOOK_VERIFY_TOKEN=

# --- IA (Zhipu AI / 智谱) — generación de preguntas de opción múltiple ---
# Clave desde https://open.bigmodel.cn/ (consola Zhipu AI / BigModel)
ZHIPU_API_KEY=
# Opcional: modelo GLM (por defecto glm-4-flash)
# ZHIPU_MODEL=glm-4-flash
# Opcional: otro endpoint compatible (por defecto chat completions v4)
# ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# --- IA Groq ---
GROQ_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_STUDENT_CHAT_ID=
TELEGRAM_TEACHER_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# --- Base de datos PostgreSQL (V2) ---
# Esquema en database/schema.sql — datos demo en database/seed.sql
# DATABASE_URL=postgresql://usuario:clave@localhost:5432/comprendo
